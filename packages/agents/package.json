{
  "name": "@charclaw/agents",
  "version": "0.2.1",
  "description": "CharClaw Agents SDK — run AI coding agents (Claude, Codex, Gemini, Goose, OpenCode, Pi) inside Daytona sandboxes or on the local machine.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "codex",
    "gemini",
    "goose",
    "opencode",
    "pi",
    "daytona",
    "sandbox",
    "sdk",
    "charclaw"
  ],
  "author": "Anit Chaudhary",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnitChaudhry/CharClaw-App.git",
    "directory": "packages/agents"
  },
  "homepage": "https://github.com/AnitChaudhry/charclaw/tree/main/packages/agents",
  "bugs": {
    "url": "https://github.com/AnitChaudhry/charclaw/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@daytonaio/sdk": "^0.148.0"
  }
}
