# ──────────────────────────────────────────────────────────────────────────
# CharClaw environment configuration
#
# Copy this file to `.env` (gitignored) or set these in your deployment
# platform's secret manager (Vercel env vars, Fly secrets, Docker secrets,
# etc.) for production. Never commit real values to git.
#
# For a full production deployment checklist, see DEPLOYMENT.md.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (required) ──────────────────────────────────────────────────
# Local dev: point at your local Postgres. Prod: Neon / Supabase / RDS / etc.
DATABASE_URL="postgres://user:password@host/database?sslmode=require"
# Unpooled connection used only by Prisma migrations.
DATABASE_URL_UNPOOLED="postgres://user:password@host/database?sslmode=require"

# ── NextAuth.js (required) ───────────────────────────────────────────────
# The absolute URL users sign in against. In production, this is your
# deployed hostname, e.g. https://app.charclaw.ai
NEXTAUTH_URL="http://localhost:3000"
# Generate with:    openssl rand -base64 32
# Losing / rotating this invalidates all existing session cookies.
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── GitHub OAuth App (required) ──────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
#   - Homepage URL:          https://your-domain.com
#   - Authorization callback: https://your-domain.com/api/auth/callback/github
# (for local dev, use http://localhost:3000 for both)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ── Encryption key (required) ────────────────────────────────────────────
# Encrypts every user's stored Anthropic/OpenAI/etc. API key at rest.
# Generate with:    openssl rand -hex 32      (64 hex chars)
# LOSING / ROTATING THIS KEY BRICKS EVERY USER'S STORED CREDENTIALS.
# Back it up the same way you'd back up a database encryption key.
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ── Optional integrations ────────────────────────────────────────────────

# Legacy cloud-sandbox provider key. Not required for local-runtime deployments.
DAYTONA_API_KEY="dtn_your_api_key"

# Smithery MCP server registry (server-side, shared for all users).
SMITHERY_API_KEY="your-smithery-api-key"

# OpenRouter free fallback — used for AI branch naming when users haven't
# set their own AI provider key.
OPENROUTER_API_KEY="your-openrouter-api-key"

# Autopilot cron tick auth — any request to /api/cron/autopilots/tick must
# carry `Authorization: Bearer ${AUTOPILOT_CRON_SECRET}`. Unset in dev; set
# in production so only your scheduler (Vercel Cron, systemd timer, etc.)
# can fire autopilots.
AUTOPILOT_CRON_SECRET="generate-with-openssl-rand-hex-32"

# ── Dev-only auth bypass (NEVER in production) ───────────────────────────
# When set AND NODE_ENV !== "production", login is skipped and a seeded
# dev user is signed in automatically. The PAT is used for real GitHub
# operations (cloning, etc.) on that dev user's behalf.
# Required scopes: repo, read:user
# Get one from: https://github.com/settings/tokens (classic)
# GITHUB_PAT=ghp_xxxxxxxxxxxx

# ── Desktop app backend URL (only relevant for Electron builds) ──────────
# Consumed by packages/desktop/src/main.ts to choose which web backend to
# load. Omit for dev (defaults to localhost:3000); set to your hosted
# backend URL at electron-builder build time to bake it into shipped
# installers.
# CHARCLAW_SERVER_URL=https://app.charclaw.ai
